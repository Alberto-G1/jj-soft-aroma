# Copy this file to .env for local development only.
# On production hosting, add these as environment variables in the hosting dashboard.
# NEVER upload or commit the real .env file.

SECRET_KEY=generate-a-long-random-secret-key

# Prefer DATABASE_URL if available
DATABASE_URL=postgresql://user:password@host:5432/jj_softaroma

# Or build a database URL from parts
DB_DRIVER=postgresql
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_HOST=your_database_host
DB_PORT=5432
DB_NAME=jj_softaroma

# Africa's Talking SMS API
AT_USERNAME=your_africastalking_username
AT_API_KEY=your_africastalking_api_key
NOTIFY_PHONE=your_notification_phone

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@example.com
SMTP_PASSWORD=your_email_app_password
SMTP_FROM_EMAIL=your_email@example.com
SMTP_USE_TLS=1

FLASK_ENV=production
FLASK_DEBUG=0
ADMIN_USERNAME=your_admin_username
ADMIN_PASSWORD=use-a-strong-password
CREATE_DEFAULT_ADMIN=false
WTF_CSRF_ENABLED=true

# Cloudinary Integration (Image Storage)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
